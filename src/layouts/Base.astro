---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Luciano Panepucci — Sinapses',
  description = 'Tecnologia, publicação científica e outras sinapses.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Sinapses" href="/rss.xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
